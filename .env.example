# ============================================================
# Phase 0（精度検証）で使う環境変数
# `.env` にコピーして値を入れる。`scripts/verify.ts` が読み込む
# ============================================================

# Claude API キー（必須）
ANTHROPIC_API_KEY=

# モデルは環境変数で差し替え可能にしておく（docs/05 の指針）
# Stage1=事実抽出は安価モデル、Stage2=仮説構築は上位モデル
MODEL_STAGE1=claude-haiku-4-5
MODEL_STAGE2=claude-sonnet-5

# Stage2 の思考（thinking）モード。原価防衛のため既定は disabled。
# 仮説の質を上げたい検証では adaptive を試す
MODEL_STAGE2_THINKING=disabled

# Web検索API（任意。未設定ならニュース収集はスキップする）
# 既定は Brave Search（X-Subscription-Token）。他プロバイダは SEARCH_PROVIDER で切替
SEARCH_PROVIDER=brave
SEARCH_API_KEY=

# --- 原価防衛パラメータ（未設定なら下記の既定値。小さくするほど安く・粗く） ---
# 収集ページ数の上限
MAX_PAGES=8
# 1ページあたりの本文トリム（文字）
MAX_PAGE_CHARS=6000
# Stage1 へ渡す本文の総量上限（文字）。原価の実効的な天井。
# 目安: 約30,000文字で Stage1(Haiku) の入力を概ね $0.03 以下に抑える
MAX_TOTAL_CHARS=30000

# --- Supabase（Phase 1。Worker はサービスロールで書き込む） ---
# SUPABASE_SERVICE_ROLE_KEY は RLS をバイパスする。サーバー側のみ。クライアントに絶対出さない
# ※ Phase 0 の検証CLI（verify）では未設定でよい
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# 会社キャッシュの有効日数（docs/02: 7日）。同一ドメインは7日以内なら収集+Stage1を省略
CACHE_TTL_DAYS=7
