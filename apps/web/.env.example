# ============================================================
# apps/web（Next.js / BFF）の環境変数（docs/02）
#   .env.local にコピーして使う
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# サーバー側のみ。RLSをバイパスするためクライアントに絶対出さない
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe（一回払いのみ） ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- アプリ ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- 生成（Worker と共通。BFFがサーバーで直接呼ぶ） ---
ANTHROPIC_API_KEY=
MODEL_STAGE1=claude-haiku-4-5
MODEL_STAGE2=claude-sonnet-5
SEARCH_API_KEY=
# 原価防衛・キャッシュ（未設定なら既定値）
MAX_TOTAL_CHARS=30000
CACHE_TTL_DAYS=7
DAILY_GLOBAL_LIMIT=500
