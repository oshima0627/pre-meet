{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "premeet",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-25",
  // Node.js 互換（@anthropic-ai/sdk / supabase-js / stripe を Workers で動かす）
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // レート制限・サーキットブレーカー用の共有KV。
  // 事前に `wrangler kv namespace create RATE_LIMIT` して id を貼る。
  "kv_namespaces": [
    { "binding": "RATE_LIMIT", "id": "e2a51a5a12f24a43a9a58e6fef06aab5" }
  ],
  // 本番でエラー原因を追えるようにログを常時有効化する。
  // （ダッシュボードで手動ONしてもデプロイのたびに戻るため、設定ファイルで固定）
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  // 公開して問題ない値（URL・匿名キー）はここに固定する。
  // 理由: wrangler deploy はダッシュボードで手動設定した Plaintext 変数を
  // 毎回リセットするため、設定ファイルに書かないとデプロイのたびに消える。
  // これらはもともとブラウザに露出する値なので秘匿性はない（RLSで保護）。
  "vars": {
    "SUPABASE_URL": "https://uwnephsbglwrsdlahgpo.supabase.co",
    "NEXT_PUBLIC_SUPABASE_URL": "https://uwnephsbglwrsdlahgpo.supabase.co",
    "NEXT_PUBLIC_APP_URL": "https://premeet.oshima6-27.workers.dev"
  }
  // 秘密（暗号化が必要な値）は Secret として登録する。Secret はデプロイで消えない。
  //   ANTHROPIC_API_KEY / SUPABASE_SERVICE_ROLE_KEY / STRIPE_SECRET_KEY /
  //   STRIPE_WEBHOOK_SECRET / SEARCH_API_KEY / NEXT_PUBLIC_SUPABASE_ANON_KEY
  // ※ 匿名キーは公開値だが、リポジトリに置きたくないため Secret 側で保持する。
}
